{
	"name": "pixi-slug",
	"version": "0.1.1",
	"description": "Render fonts in pixi.js using bezier curves with the slug algorithm.",
	"main": "./dist/v8/index.js",
	"types": "./dist/v8/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/v8/index.d.ts",
			"import": "./dist/v8/index.js",
			"require": "./dist/v8/index.js",
			"default": "./dist/v8/index.js"
		},
		"./v7": {
			"types": "./dist/v7/index.d.ts",
			"import": "./dist/v7/index.js",
			"require": "./dist/v7/index.js",
			"default": "./dist/v7/index.js"
		},
		"./v6": {
			"types": "./dist/v6/index.d.ts",
			"import": "./dist/v6/index.js",
			"require": "./dist/v6/index.js",
			"default": "./dist/v6/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build:v6:dev": "webpack --env version=v6 --env target=dev && tsc -p tsconfig.v6.json --emitDeclarationOnly && node scripts/flatten-types.mjs",
		"build:v6:prod": "webpack --env version=v6 --env target=prod && tsc -p tsconfig.v6.json --emitDeclarationOnly && node scripts/flatten-types.mjs",
		"build:v7:dev": "webpack --env version=v7 --env target=dev && tsc -p tsconfig.v7.json --emitDeclarationOnly && node scripts/flatten-types.mjs",
		"build:v7:prod": "webpack --env version=v7 --env target=prod && tsc -p tsconfig.v7.json --emitDeclarationOnly && node scripts/flatten-types.mjs",
		"build:v8:dev": "webpack --env version=v8 --env target=dev && tsc -p tsconfig.v8.json --emitDeclarationOnly && node scripts/flatten-types.mjs",
		"build:v8:prod": "webpack --env version=v8 --env target=prod && tsc -p tsconfig.v8.json --emitDeclarationOnly && node scripts/flatten-types.mjs",
		"build:all:dev": "webpack --env version=all --env target=dev && pnpm run build:types",
		"build:all:prod": "webpack --env version=all --env target=prod && pnpm run build:types",
		"build:v6": "pnpm run build:v6:prod",
		"build:v7": "pnpm run build:v7:prod",
		"build:v8": "pnpm run build:v8:prod",
		"build:all": "pnpm run build:all:prod",
		"build:docs": "node scripts/build-docs.js",
		"build:fallback-font": "node scripts/build-fallback-font.mjs",
		"build:types": "tsc -p tsconfig.v8.json --emitDeclarationOnly && tsc -p tsconfig.v7.json --emitDeclarationOnly && tsc -p tsconfig.v6.json --emitDeclarationOnly && node scripts/flatten-types.mjs",
		"test": "cross-env COVERAGE=full jest --coverage",
		"test:ci": "cross-env COVERAGE=full jest --ci --coverage --maxWorkers=50% --reporters=default --reporters=jest-junit",
		"test:fast": "cross-env COVERAGE=summary jest --bail --coverage",
		"examples": "serve . -l 3000 --cors --no-clipboard",
		"examples:watch": "webpack --watch --env version=all --env target=dev & serve . -l 3000 --cors --no-clipboard"
	},
	"keywords": [
		"slug",
		"slug-algorithm",
		"slug-library",
		"pixijs",
		"pixi",
		"pixi-plugin",
		"font-rendering",
		"text-rendering",
		"vector-text",
		"vector-fonts",
		"glyph-rendering",
		"glyph",
		"outline-fonts",
		"scalable-text",
		"resolution-independent",
		"bezier",
		"bezier-curves",
		"quadratic-bezier",
		"sdf",
		"msdf",
		"gpu-text",
		"shader-text",
		"webgl",
		"webgl2"
	],
	"author": "Toreda, Inc.",
	"license": "MIT",
	"packageManager": "pnpm@10.11.1",
	"prettier": "@toreda/prettier-config",
	"peerDependencies": {
		"pixi.js": "^6.0.0 || ^7.0.0 || ^8.0.0"
	},
	"peerDependenciesMeta": {
		"pixi.js": {
			"optional": true
		}
	},
	"devDependencies": {
		"@shaderfrog/glsl-parser": "^7.0.1",
		"@swc/core": "^1.15.18",
		"@swc/jest": "^0.2.39",
		"@toreda/eslint-config": "^2.2.0",
		"@toreda/prettier-config": "^1.0.1",
		"@types/jest": "^30.0.0",
		"@types/opentype.js": "^1.3.9",
		"@types/webpack": "^5.28.5",
		"cross-env": "^10.1.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-prettier-config": "^1.0.1",
		"jest": "^30.3.0",
		"jest-junit": "^16.0.0",
		"pixi-v6-constants": "npm:@pixi/constants@^6.5.10",
		"pixi-v6-core": "npm:@pixi/core@^6.5.10",
		"pixi-v6-display": "npm:@pixi/display@^6.5.10",
		"pixi-v6-graphics": "npm:@pixi/graphics@^6.5.10",
		"pixi-v6-mesh": "npm:@pixi/mesh@^6.5.10",
		"pixi-v6-ticker": "npm:@pixi/ticker@^6.5.10",
		"pixi-v7-constants": "npm:@pixi/constants@^7.4.3",
		"pixi-v7-core": "npm:@pixi/core@^7.4.3",
		"pixi-v7-display": "npm:@pixi/display@^7.4.3",
		"pixi-v7-graphics": "npm:@pixi/graphics@^7.4.3",
		"pixi-v7-mesh": "npm:@pixi/mesh@^7.4.3",
		"pixi-v7-ticker": "npm:@pixi/ticker@^7.4.3",
		"pixi.js": "^8.0.0",
		"prettier": "^3.8.1",
		"serve": "^14.2.6",
		"terser-webpack-plugin": "^5.4.0",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"typed-glsl": "^0.11.2",
		"typescript": "^5.9.3",
		"webpack": "^5.105.4",
		"webpack-cli": "^7.0.2"
	},
	"dependencies": {
		"@toreda/fate": "^0.7.0",
		"@toreda/strong-types": "^0.28.5",
		"@toreda/verify": "^0.12.3",
		"opentype.js": "^1.3.4",
		"woff2-encoder": "^2.0.0"
	}
}
